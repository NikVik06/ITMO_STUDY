import java.io.File;
import java.io.FileNotFoundException;
import java.util.Date;
import java.util.InputMismatchException;
import java.util.Scanner;

public class SLAUSolver {
    private double[][] A;
    private double[] b;
    private int n;

    public SLAUSolver(int size) {
        this.n = size;
        this.A = new double[size][size];
        this.b = new double[size];
    }

    public void readFromConsole() {
        Scanner scanner = new Scanner(System.in);
        if (A == null || b == null) {
            System.out.println("Ошибка: массивы не инициализированы!");
            return;
        }
        System.out.println("Введите матрицу A построчно (по " + n + " чисел в строке):");
        for (int i = 0; i < n; i++) {
            System.out.printf("Строка %d: ", i+1);
            for (int j = 0; j < n; j++) {
                while (!scanner.hasNextDouble()) {
                    System.out.println("Ошибка: введите число!");
                    scanner.next(); // пропускаем неверный ввод
                }
                A[i][j] = scanner.nextDouble();
            }
        }
        System.out.println("Введите вектор правой части b (" + n + " чисел через пробел):");
        for (int i = 0; i < n; i++) {
            while (!scanner.hasNextDouble()) {
                System.out.println("Ошибка: введите число!");
                scanner.next();
            }
            b[i] = scanner.nextDouble();
        }
    }

    public void readFromFile(String filename) {
        try {
            Scanner scanner = new Scanner(new File(filename));
            if (!scanner.hasNextInt()) {
                System.out.println("Ошибка: файл не содержит размерности");
                n = 0;
                return;
            }
            n = scanner.nextInt();

            if (n > 20) {
                System.out.println("Ошибка: размерность матрицы больше 20");
                n = 0;
                return;
            }
            A = new double[n][n];
            b = new double[n];

            for (int i = 0; i < n;i++) {
                for (int j = 0; j < n; j++) {
                    if (!scanner.hasNextDouble()) {
                        System.out.println("Ошибка: недостаточно данных в файле");
                        n = 0;
                        return;
                    }
                    A[i][j] = scanner.nextDouble();
                }
            }

            for (int i = 0; i< n; i++) {
                if (!scanner.hasNextDouble()) {
                    System.out.println("Ошибка: недостаточно данных в файле");
                    n = 0;
                    return;
                }
                b[i] = scanner.nextDouble();
            }
            scanner.close();
            System.out.println("Данные успешно загружены из файла " + filename);
            System.out.println("Размерность системы: " + n);
        } catch (FileNotFoundException e) {
            System.out.println("Файл не найден");
            n = 0;
        } catch (Exception e) {
            System.out.println("Ошибка при чтении файла: " + e.getMessage());
            n = 0;
        }
    }

    public void printMatrix() {
        if (A == null) {
            System.out.println("Ошибка: матрица не инициализирована!");
            return;
        }
        if (n == 0) {
            System.out.println("Матрица пуста");
            return;
        }
        System.out.println("Матрица А");
        for (int i = 0; i < n; i++) {
            for (int j = 0; j < n;j++) {
                System.out.printf("%8.3f",A[i][j]);
            }
            System.out.printf("| %8.3f\n", b[i]);
        }
    }

    public boolean hasDiagonalDominance() {
        for (int i = 0; i< n;i++) {
            double diagonal = Math.abs(A[i][i]);
            double sum = 0;
            for (int j = 0; j < n;j++) {
                if(j != i) {
                    sum += Math.abs(A[i][j]);
                }
            }
            if (diagonal <= sum) {
                System.out.printf("Строка %d: |%f| <= %f - преобладания нет\n", i+1, diagonal,sum);
                return false;
            } else {
                System.out.printf("Строка %d: |%f| <= %f - есть преобладания\n", i+1, diagonal,sum);
            }
        }
        return true;
    }

    public boolean makeDiagonalDominant() {
        double[][] tempA = new double[n][n];
        double[] tempB = new double[n];

        for (int i = 0; i < n; i++) {
            tempB[i] = b[i];
            for(int j = 0;j < n; j++) {
                tempA[i][j] = A[i][j];
            }
        }

        for (int i = 0; i < n;i++) {
            int maxRow = i;
            double maxElement = Math.abs(tempA[i][i]);
            for (int k = i + 1; k < n; k++) {
                if(Math.abs(tempA[k][i]) > maxElement) {
                    maxElement = Math.abs(tempA[k][i]);
                    maxRow = k;
                }
            }
            if (maxRow != i) {
                double[] rowTemp = tempA[i];
                tempA[i] = tempA[maxRow];
                tempA[maxRow] = rowTemp;

                double bTemp = tempB[i];
                tempB[i] = tempB[maxRow];
                tempB[maxRow] = bTemp;
            }

            double diagonal = Math.abs(tempA[i][i]);
            double sum = 0;
            for (int j = 0; j < n;j++) {
                if (j != i) {
                    sum += Math.abs(tempA[i][j]);
                }
            }
            if (diagonal <= sum) {
                System.out.println("Невозможно достичь диагонального преобладания");
                return false;
            }

        }
        for (int i = 0; i < n; i++) {
            b[i] = tempB[i];
            for (int j = 0; j < n; j++) {
                A[i][j] = tempA[i][j];
            }
        }
        System.out.println("Матрица после перестановки");
        printMatrix();
        return true;

    }

    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        SLAUSolver solver = null;
        boolean inputSuccess = false;

        System.out.println("=== Решение СЛАУ методом Гаусса-Зейделя ===");

        // Цикл для повторения ввода пока не получится
        while (!inputSuccess) {
            try {
                // Выбор способа ввода
                System.out.println("\nВыберите способ ввода данных:");
                System.out.println("1 - с клавиатуры");
                System.out.println("2 - из файла");
                System.out.println("0 - выход из программы");
                System.out.print("Ваш выбор: ");

                int choice = scanner.nextInt();

                if (choice == 0) {
                    System.out.println("Программа завершена.");
                    return;
                }

                if (choice == 1) {
                    // Ввод с клавиатуры
                    System.out.print("Введите размерность системы n (n <= 20): ");
                    int n = scanner.nextInt();
                    if (n < 0 || n > 20) {
                        System.out.println("Ошибка: n должно быть от 1 до 20. Попробуйте снова.");
                        continue;
                    }
                    solver = new SLAUSolver(n);
                    solver.readFromConsole();
                    if (solver.A != null && solver.A.length == n) {
                        inputSuccess = true;
                        System.out.println("Матрица успешно загружена!");
                    } else {
                        System.out.println("Ошибка при чтении матрицы. Попробуйте снова.");
                    }

                } else if (choice == 2) {
                    // Ввод из файла
                    System.out.print("Введите имя файла: ");
                    String filename = scanner.next();

                    // Проверяем существование файла
                    File file = new File(filename);
                    if (!file.exists()) {
                        System.out.println("Ошибка: файл '" + filename + "' не найден!");
                        continue;
                    }

                    solver = new SLAUSolver(1); // временно
                    solver.readFromFile(filename);

                    if (solver.n > 0 && solver.n <= 20 && solver.A != null) {
                        inputSuccess = true;
                    } else {
                        System.out.println("Ошибка при чтении файла. Попробуйте снова.");
                    }

                } else {
                    System.out.println("Неверный выбор. Пожалуйста, введите 1, 2 или 0.");
                }

            } catch (InputMismatchException e) {
                System.out.println("Ошибка: введите число!");
                scanner.nextLine(); // очищаем буфер
            } catch (Exception e) {
                System.out.println("Произошла ошибка: " + e.getMessage());
                scanner.nextLine(); // очищаем буфер
            }
        }

        // Ввод точности с защитой от ошибок
        double epsilon = 0;
        boolean epsilonSuccess = false;
        while (!epsilonSuccess) {
            try {
                System.out.print("Введите точность epsilon (например, 0.001): ");
                String epsilonStr = scanner.next();
                epsilonStr = epsilonStr.replace(',','.');
                epsilon = Double.parseDouble(epsilonStr);
                if (epsilon <= 0) {
                    System.out.println("Ошибка: точность должна быть положительным числом!");
                    continue;
                }
                epsilonSuccess = true;
            } catch (InputMismatchException e) {
                System.out.println("Ошибка: введите число!");
                scanner.nextLine(); // очищаем буфер
            }
        }

        // Выводим исходные данные
        System.out.println("\nИсходная система:");
        solver.printMatrix();

        // Проверяем размерность
        if (solver.n > 20) {
            System.out.println("Ошибка: размерность матрицы больше 20!");
            return;
        }

        // Проверяем и исправляем диагональное преобладание
        System.out.println("\nПроверка диагонального преобладания:");
        if (solver.hasDiagonalDominance()) {
            System.out.println("Матрица подходит для метода Зейделя!");
        } else {
            System.out.println("Диагональное преобладание отсутствует. Пытаемся переставить строки...");
            if (solver.makeDiagonalDominant()) {
                System.out.println("Преобладание достигнуто! Новая матрица:");
                solver.printMatrix();
            } else {
                System.out.println("Невозможно достичь диагонального преобладания.");
                System.out.println("Метод Зейделя не может быть применен к этой системе.");
                return;
            }
        }

        // Вычисляем и выводим норму
        double norm = solver.getRowNorm();
        System.out.println("\nСтрочная норма матрицы: " + norm);

        // Решаем систему
        double[] solution = solver.solveSeidel(epsilon);

        // Выводим результат
        System.out.println("\n=== Окончательное решение ===");
        for (int i = 0; i < solver.n; i++) {
            System.out.printf("x%d = %f\n", i+1, solution[i]);
        }
    }

    public double getRowNorm() {
        double maxRowSum = 0;

        for(int i = 0; i < n; i++) {
            double rowSum = 0;
            for (int j = 0; j < n;j++) {
                rowSum += Math.abs(A[i][j]);
            }
            if (rowSum > maxRowSum) {
                maxRowSum = rowSum;
            }
        }
        return maxRowSum;
    }

    public double[] solveSeidel(double epsilon) {
        double[] x = new double[n];
        double[] oldX = new double[n];
        double[] errors = new double[n];
        int iterations = 0;
        double maxDiff;
        System.out.println("\nНачинаем итерационный процесс...");
        System.out.println("Точность: " + epsilon);
        do {
            System.arraycopy(x,0,oldX,0,n);
            for (int i = 0; i < n;i++) {
                double sum1 = 0;
                double sum2 = 0;
                for (int j = 0; j < i; j++) {
                    sum1 += A[i][j] * x[j];
                }
                for (int j = i + 1; j < n; j++) {
                    sum1 += A[i][j] * oldX[j];
                }

                x[i] = (b[i] - sum1 - sum2) / A[i][i];
            }
            maxDiff = 0;
            for (int i = 0; i< n;i++) {
                double diff = Math.abs(x[i] - oldX[i]);
                errors[i] = diff;
                if (diff > maxDiff) {
                    maxDiff = diff;
                }
            }
            iterations++;
            System.out.printf("Итерация %d: maxDiff = %f\n",iterations,maxDiff);
            for (int i = 0; i < n;i++) {
                System.out.printf(" x[%d] = %f\n", i+1,x[i]);
            }
        } while (maxDiff >= epsilon && iterations < 1000);
        System.out.println("\nРешение найдено за " + iterations + " итераций");
        System.out.println("Вектор погрешностей на последней итерации:");
        for (int i = 0; i < n;i++) {
            System.out.printf("|x%d^(k) - x%d^(k-1)| = %f\n", i+1,i+1,errors[i]);
        }
        return x;
    }


}

